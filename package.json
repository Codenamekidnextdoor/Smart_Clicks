{
  "name": "smartclick",
  "version": "1.0.0",
  "description": "AI-powered cursor layer that brings IBM Bob directly into any application",
  "homepage": "https://github.com/Codenamekidnextdoor/Smart_Clicks#readme",
  "bugs": {
    "url": "https://github.com/Codenamekidnextdoor/Smart_Clicks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Codenamekidnextdoor/Smart_Clicks.git"
  },
  "license": "ISC",
  "author": "",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "clean": "node scripts/clean.js"
  },
  "dependencies": {
    "@ibm-cloud/watsonx-ai": "^1.0.0",
    "ibm-cloud-sdk-core": "^4.0.0",
    "electron-store": "^8.1.0",
    "pg": "^8.11.0",
    "pg-pool": "^3.6.0",
    "dotenv": "^16.3.1",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/pg": "^8.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "playwright": "^1.40.0"
  },
  "directories": {
    "doc": "docs"
  },
  "keywords": [
    "ai",
    "electron",
    "ibm",
    "watsonx",
    "productivity",
